generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  password     String
  roleId       String     @map("role_id") @db.Uuid
  employeeId   String?    @unique @map("employee_id") @db.Uuid
  status       UserStatus @default(ACTIVE)
  refreshToken String?    @map("refresh_token")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  employee     Employee?  @relation(fields: [employeeId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])
  auditLogs    AuditLog[]

  @@index([roleId])
  @@map("users")
}

model Role {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  permissions Permission[]
  users       User[]

  @@map("roles")
}

model Module {
  id          String       @id @default(uuid()) @db.Uuid
  moduleName  String       @unique @map("module_name")
  permissions Permission[]

  @@map("modules")
}

model Permission {
  id        String  @id @default(uuid()) @db.Uuid
  roleId    String  @map("role_id") @db.Uuid
  moduleId  String  @map("module_id") @db.Uuid
  canView   Boolean @default(false) @map("can_view")
  canCreate Boolean @default(false) @map("can_create")
  canUpdate Boolean @default(false) @map("can_update")
  canDelete Boolean @default(false) @map("can_delete")
  module    Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  role      Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId])
  @@map("permissions")
}

model Department {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     @unique
  employees Employee[]

  @@map("departments")
}

model Employee {
  id            String              @id @default(uuid()) @db.Uuid
  name          String
  phone         String?
  departmentId  String?             @map("department_id") @db.Uuid
  designation   String
  joiningDate   DateTime            @map("joining_date")
  status        EmployeeStatus      @default(ACTIVE)
  currentSalary Decimal?            @map("current_salary") @db.Decimal(12, 2)
  attendance    Attendance[]
  documents     EmployeeDocument[]
  managers      EmployeeHierarchy[] @relation("EmployeeManagers")
  reports       EmployeeHierarchy[] @relation("ManagerReports")
  department    Department?         @relation(fields: [departmentId], references: [id])
  leaves        Leave[]
  salaryHistory SalaryHistory[]
  taskUpdates   TaskHistory[]
  assignedTasks Task[]              @relation("TaskAssignee")
  createdTasks  Task[]              @relation("TaskCreator")
  user          User?

  @@index([departmentId])
  @@map("employees")
}

model EmployeeDocument {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  fileName   String   @map("file_name")
  filePath   String   @map("file_path")
  mimeType   String   @map("mime_type")
  createdAt  DateTime @default(now()) @map("created_at")
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_documents")
}

model EmployeeHierarchy {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  managerId  String   @map("manager_id") @db.Uuid
  level      Int
  employee   Employee @relation("EmployeeManagers", fields: [employeeId], references: [id], onDelete: Cascade)
  manager    Employee @relation("ManagerReports", fields: [managerId], references: [id], onDelete: Cascade)

  @@unique([employeeId, managerId])
  @@map("employee_hierarchy")
}

model Attendance {
  id         String           @id @default(uuid()) @db.Uuid
  employeeId String           @map("employee_id") @db.Uuid
  date       DateTime         @db.Date
  checkIn    DateTime?        @map("check_in")
  checkOut   DateTime?        @map("check_out")
  status     AttendanceStatus @default(PRESENT)
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@map("attendance")
}

model Leave {
  id         String      @id @default(uuid()) @db.Uuid
  employeeId String      @map("employee_id") @db.Uuid
  type       String
  fromDate   DateTime    @map("from_date") @db.Date
  toDate     DateTime    @map("to_date") @db.Date
  status     LeaveStatus @default(PENDING)
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("leaves")
}

model SalaryHistory {
  id            String   @id @default(uuid()) @db.Uuid
  employeeId    String   @map("employee_id") @db.Uuid
  oldSalary     Decimal  @map("old_salary") @db.Decimal(12, 2)
  newSalary     Decimal  @map("new_salary") @db.Decimal(12, 2)
  incrementDate DateTime @map("increment_date") @db.Date
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("salary_history")
}

model Task {
  id          String        @id @default(uuid()) @db.Uuid
  title       String
  description String?
  department  String?
  createdBy   String        @map("created_by") @db.Uuid
  assignedTo  String?       @map("assigned_to") @db.Uuid
  status      TaskStatus    @default(TODO)
  priority    TaskPriority  @default(MEDIUM)
  deadline    DateTime?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  history     TaskHistory[]
  assignee    Employee?     @relation("TaskAssignee", fields: [assignedTo], references: [id])
  creator     Employee      @relation("TaskCreator", fields: [createdBy], references: [id])

  @@index([assignedTo])
  @@index([createdBy])
  @@map("tasks")
}

model TaskHistory {
  id        String   @id @default(uuid()) @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  updatedBy String   @map("updated_by") @db.Uuid
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  createdAt DateTime @default(now()) @map("created_at")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  updater   Employee @relation(fields: [updatedBy], references: [id])

  @@index([taskId])
  @@index([updatedBy])
  @@map("task_history")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  resource  String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("audit_logs")
}

model Category {
  id       String    @id @default(uuid()) @db.Uuid
  name     String    @unique
  products Product[]

  @@map("categories")
}

model Product {
  id           String             @id @default(uuid()) @db.Uuid
  name         String
  sku          String             @unique
  categoryId   String?            @map("category_id") @db.Uuid
  inventory    Inventory?
  category     Category?          @relation(fields: [categoryId], references: [id])
  invoiceItems SalesInvoiceItem[]
  movements    StockMovement[]

  @@index([categoryId])
  @@map("products")
}

model Inventory {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @unique @map("product_id") @db.Uuid
  quantity  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory")
}

model StockMovement {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  type      String
  quantity  Int
  createdAt DateTime @default(now()) @map("created_at")
  product   Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("stock_movements")
}

model Vendor {
  id    String  @id @default(uuid()) @db.Uuid
  name  String
  phone String?

  @@map("vendors")
}

model Customer {
  id       String         @id @default(uuid()) @db.Uuid
  name     String
  phone    String?
  invoices SalesInvoice[]

  @@map("customers")
}

model SalesInvoice {
  id            String               @id @default(uuid()) @db.Uuid
  customerId    String               @map("customer_id") @db.Uuid
  total         Decimal              @db.Decimal(12, 2)
  createdAt     DateTime             @default(now()) @map("created_at")
  invoiceNumber String               @unique @map("invoice_number")
  paymentStatus InvoicePaymentStatus @default(PENDING) @map("payment_status")
  paidAmount    Decimal              @default(0) @map("paid_amount") @db.Decimal(12, 2)
  items         SalesInvoiceItem[]
  customer      Customer             @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("sales_invoices")
}

model SalesInvoiceItem {
  id        String       @id @default(uuid()) @db.Uuid
  invoiceId String       @map("invoice_id") @db.Uuid
  productId String       @map("product_id") @db.Uuid
  quantity  Int
  price     Decimal      @db.Decimal(12, 2)
  invoice   SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
  @@map("sales_invoice_items")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum EmployeeStatus {
  ACTIVE
  DISABLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvoicePaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
